# Public hostname for the production deployment.
DOMAIN=commentary.example.com

# Email used by Let's Encrypt for certificate notices.
ACME_EMAIL=ops@example.com

# Browser origin allowed by FastAPI CORS.
CORS_ORIGINS=https://commentary.example.com

# App behavior
SPORT=cricket
CRICKET_LEAGUE=ipl
CRICKET_LEAGUES=
POLL_INTERVAL_SEC=10
CRICKET_POLL_INTERVAL=30
COMMENTARY_STYLE=default

# Kafka topics
TOPIC_RAW_EVENTS=game-events
TOPIC_ENRICHED=enriched-events
TOPIC_COMMENTARY=commentary-output
TOPIC_DLQ=commentary-dlq

# LLM provider: prefer a hosted provider in production.
# Options: openai | claude | ollama
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_MODEL=llama3
