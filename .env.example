# ============================================================
#  AI Sports Commentary Engine — Environment Variables
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
# ============================================================

# ── SPORT ─────────────────────────────────────────────────
# Options: nba | nfl | nhl | soccer | cricket
SPORT=cricket

# ── CRICKET LEAGUE (only used when SPORT=cricket) ────────
# Options: ipl | psl | bbl | shield | hundred | cpl | sa20
CRICKET_LEAGUE=ipl

# ── LLM PROVIDER ─────────────────────────────────────────
# Options: ollama | openai | claude
LLM_PROVIDER=ollama

# ── API KEYS (fill in only the one you're using) ─────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── OLLAMA (local LLM — free, no API key needed) ─────────
# Install: https://ollama.com  then: ollama pull llama3
OLLAMA_MODEL=llama3

# ── COMMENTARY STYLE ─────────────────────────────────────
# Options: default | bhogle | bishop | shastri | benaud
COMMENTARY_STYLE=default

# ── KAFKA ─────────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:9092

# ── POLLING ───────────────────────────────────────────────
# Seconds between ESPN API polls (cricket auto-adjusts to 30s)
POLL_INTERVAL_SEC=10

# ── TTS (text-to-speech, optional) ───────────────────────
# Options: off | pyttsx3 | gtts
TTS_ENGINE=off
